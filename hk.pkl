amends "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Builtins.pkl"

local formatters = new Mapping<String, Step> {
    ["ruff"] = Builtins.ruff
    ["ruff_format"] = (Builtins.ruff_format) {
        output_summary = "hide"
    }
    ["prettier"] = Builtins.prettier
    ["pkl"] = Builtins.pkl
    ["newlines"] = Builtins.newlines
    ["mixed_line_ending"] = Builtins.mixed_line_ending
    ["trailing_whitespace"] = Builtins.trailing_whitespace
    ["shfmt"] = Builtins.shfmt
    ["just"] {
        workspace_indicator = "hk.pkl"
        fix = "just --fmt --unstable {{workspace}}"
    }
    ["mise"] {
        workspace_indicator = "hk.pkl"
        fix = "mise fmt"
    }
}

local linters = new Mapping<String, Step> {
    ["detect_private_key"] = Builtins.detect_private_key
    ["gitleaks"] {
        workspace_indicator = "hk.pkl"
        check = "gitleaks git {{workspace}} --no-banner --pre-commit --log-level=fatal"
    }
    ["shellcheck"] = (Builtins.shellcheck) {
        check = "shellcheck --severity=error {{files}}"
    }
    ["trufflehog"] {
        glob = List("*")
        workspace_indicator = "hk.pkl"
        check = "trufflehog filesystem --fail --no-update --no-verification --exclude-detectors=Postgres,RabbitMQ,JDBC {{files}}"
        output_summary = "hide"
    }
    ["detect-secrets"] {
        glob = List("*")
        exclude = List("docker/*", "*deprecated*")
        check = "detect-secrets-hook -n --disable-plugin KeywordDetector --disable-plugin Base64HighEntropyString --disable-plugin HexHighEntropyString --disable-plugin BasicAuthDetector {{files}}"
    }
}

hooks {
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps = new Mapping<String, Step> { ...formatters ...linters }
    }
    ["check"] {
        fix = false
        steps = new Mapping<String, Step> { ...formatters ...linters }
    }
    ["fix"] {
        fix = true
        steps = formatters
    }
}
